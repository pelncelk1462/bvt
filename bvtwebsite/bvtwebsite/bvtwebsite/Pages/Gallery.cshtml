@page
@model bvtwebsite.Pages.GalleryModel

@{
    ViewData["Title"] = "Galeri";
}

<section style="padding:40px;">
    <h1>Galeri</h1>

    @if (!Model.GalleryItems.Any())
    {
        <p>Henüz yayınlanmış galeri öğesi yok.</p>
    }
    else
    {
        <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(250px, 1fr)); gap:20px;">
            @foreach (var item in Model.GalleryItems)
            {
                <div style="border:1px solid #ccc; border-radius:16px; overflow:hidden; background:white;">
                    <img src="@item.ImagePath" alt="@item.Title" style="width:100%; height:220px; object-fit:cover;" />
                    <div style="padding:16px;">
                        <h3 style="margin-top:0;">@item.Title</h3>

                        @if (!string.IsNullOrWhiteSpace(item.Description))
                        {
                            <p>@item.Description</p>
                        }
                    </div>
                </div>
            }
        </div>
    }
</section>