@page
@model AboutModel
@{
    ViewData["Title"] = "Hakkımızda";
}

<section class="about-hero">
    <div class="about-hero-card">
        <img src="~/images/ekipfoto.jpeg" alt="BANÜ Voleybol Topluluğu" class="about-hero-image" />
    </div>
</section>

<section class="about-content">
    <div class="about-content-box">
        <h1>Hakkımızda</h1>
        <p>
            BANÜ Voleybol Topluluğu, voleybola ilgi duyan öğrencileri bir araya getiren,
            takım ruhunu, dayanışmayı ve spor kültürünü geliştirmeyi amaçlayan bir topluluktur.
        </p>
        <p>
            Topluluğumuz; antrenmanlar, etkinlikler, turnuvalar ve sosyal organizasyonlarla
            üyelerine hem sportif hem sosyal açıdan aktif bir ortam sunar.
        </p>
    </div>
</section>