@page "{id:int}"
@model bvtwebsite.Pages.Admin.Events.DeleteModel
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin,Editor")]

@{
    ViewData["Title"] = "Etkinlik Sil";
}

<div class="admin-card">
    <div class="admin-page-header">
        <h1>Etkinliği Sil</h1>
        <a asp-page="Index" class="admin-btn-secondary">Geri Dön</a>
    </div>

    <p>Bu etkinliği silmek istediğine emin misin?</p>

    <div style="margin:20px 0; padding:16px; border-radius:12px; background:#f8fafc; border:1px solid #e5e7eb;">
        <strong>@Model.Event.Title</strong>

        @if (!string.IsNullOrWhiteSpace(Model.Event.LocationName))
        {
            <div style="margin-top:8px;">
                <strong>Konum:</strong> @Model.Event.LocationName
            </div>
        }

        <div style="margin-top:8px;">
            <strong>Tarih:</strong> @Model.Event.StartDate.ToString("dd.MM.yyyy HH:mm")
        </div>
    </div>

    <form method="post">
        <input type="hidden" asp-for="Event.Id" />
        <button type="submit" class="admin-btn">Sil</button>
    </form>
</div>