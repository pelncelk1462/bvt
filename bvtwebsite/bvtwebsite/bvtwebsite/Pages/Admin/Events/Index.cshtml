@page
@model bvtwebsite.Pages.Admin.Events.IndexModel
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin,Editor")]

@{
    ViewData["Title"] = "Etkinlikler";
}

<div class="admin-card">
    <div class="admin-page-header">
        <h1>Etkinlikler</h1>
        <a asp-page="Create" class="admin-btn">Yeni Etkinlik Ekle</a>
    </div>

    @if (!Model.Events.Any())
    {
        <div class="admin-empty">
            Henüz hiç etkinlik eklenmemiş.
        </div>
    }
    else
    {
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Başlık</th>
                    <th>Tarih</th>
                    <th>Konum</th>
                    <th>Durum</th>
                    <th>Onay</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Events)
                {
                    <tr>
                        <td>@item.Title</td>
                        <td>@item.StartDate.ToString("dd.MM.yyyy HH:mm")</td>
                        <td>@item.LocationName</td>
                        <td>@item.Status</td>
                        <td>@(item.IsApproved ? "Onaylandı" : "Bekliyor")</td>
                        <td>
                            <div class="admin-actions">
                                <a asp-page="Edit" asp-route-id="@item.Id" class="admin-link">Düzenle</a>
                                <a asp-page="Delete" asp-route-id="@item.Id" class="admin-link-danger">Sil</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>