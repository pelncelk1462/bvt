@page
@model bvtwebsite.Pages.Admin.Announcements.IndexModel
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin")]

@{
    ViewData["Title"] = "Duyurular";
}

<div class="admin-card">
    <div class="admin-page-header">
        <h1>Duyurular</h1>
        <a asp-page="Create" class="admin-btn">Yeni Duyuru Ekle</a>
    </div>

    @if (!Model.Announcements.Any())
    {
        <div class="admin-empty">
            Henüz hiç duyuru eklenmemiş.
        </div>
    }
    else
    {
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Başlık</th>
                    <th>Durum</th>
                    <th>Tarih</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Announcements)
                {
                    <tr>
                        <td>@item.Title</td>
                        <td>@(item.IsPublished ? "Yayında" : "Taslak")</td>
                        <td>@item.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                        <td>
                            <div class="admin-actions">
                                <a asp-page="Edit" asp-route-id="@item.Id" class="admin-link">Düzenle</a>
                                <a asp-page="Delete" asp-route-id="@item.Id" class="admin-link-danger">Sil</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>